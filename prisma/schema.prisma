generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Telemetry {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  pm25        Int
  pm10        Int
  voc         Int
  temperature Float
  humidity    Float
  co2         Int
}
